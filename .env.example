# LLM 配置（更新）
PRIMARY_MODEL=qwen-max
API_KEY=your_api_key
MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 备用 LLM（可选）
FALLBACK_MODEL=
FALLBACK_API_KEY=
FALLBACK_BASE_URL=

# 兜底回复
FALLBACK_REPLY=卖家暂时离开了，回来马上回复！

# LangSmith 监控（可选）
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=goofish-customer

# Required
COOKIES_STR=your_xianyu_cookies

# Optional
TOGGLE_KEYWORDS=#manual
SIMULATE_HUMAN_TYPING=False
LOG_LEVEL=DEBUG
HEARTBEAT_INTERVAL=15
HEARTBEAT_TIMEOUT=5
TOKEN_REFRESH_INTERVAL=3600
TOKEN_RETRY_INTERVAL=300
MANUAL_MODE_TIMEOUT=3600
MESSAGE_EXPIRE_TIME=300000
